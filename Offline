using Mapsui.UI.WinForms;
using Mapsui.Tiling.Layers;
using BruTile.MbTiles;

// Harita kontrolünü oluştur ve forma ekle
var mapControl = new MapControl();
mapControl.Dock = DockStyle.Fill;
this.Controls.Add(mapControl);

// MBTiles dosyasını oku
string mbtilesYolu = @"C:\dosya_yolu\harita.mbtiles";

// SQLite bağlantısı ile tile kaynağını oluştur (false: read-only)
var mbTilesKaynagi = new MbTilesTileSource(new SQLiteConnectionString(mbtilesYolu, false));

// Kaynağı bir harita katmanına (layer) dönüştür
var mbTilesKatmani = new TileLayer(mbTilesKaynagi) { Name = "Çevrimdışı Harita" };

// Katmanı Mapsui haritasına ekle
mapControl.Map.Layers.Add(mbTilesKatmani);
